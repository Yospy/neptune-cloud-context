# Placeholder-only example. Copy to .env and replace every value.

# Supabase project URL, for example https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key. This is browser-safe but still project-specific.
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Backend-only Supabase service role key.
# Never expose this in client code, browser bundles, logs, issues, or docs.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-server-only-service-role-key

# Local backend defaults.
PORT=8787
NODE_ENV=development
LOG_LEVEL=info
LOG_PRETTY=true
HEALTH_LOG_INTERVAL_MS=60000

# Optional CLI/MCP backend URL. Set this when running the backend locally.
NEPTUNE_API_URL=http://127.0.0.1:8787
