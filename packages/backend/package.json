{
  "name": "@neptune/backend",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "corepack pnpm --filter neptune-context-shared build",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:integration": "NEPTUNE_INTEGRATION_TESTS=true vitest run test/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "neptune-context-shared": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "@supabase/supabase-js": "^2.48.1",
    "dotenv": "^17.4.2",
    "hono": "^4.6.17",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
