    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "neptune-context": "workspace:^",
    "neptune-context-shared": "workspace:^",
    "@supabase/supabase-js": "^2.48.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
