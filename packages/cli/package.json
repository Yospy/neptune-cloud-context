{
  "name": "neptune-context-cli",
  "version": "0.1.12",
  "license": "MIT",
  "type": "module",
  "bin": {
    "neptune": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "corepack pnpm --filter neptune-context build",
