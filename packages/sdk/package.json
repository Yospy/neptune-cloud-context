{
  "name": "neptune-context",
  "version": "0.1.10",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "corepack pnpm --filter neptune-context-shared build",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "neptune-context-shared": "workspace:^",
    "@supabase/supabase-js": "^2.48.1"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
